# Copy to .env at repo root and fill in values.
# Never commit .env — it is gitignored.

# ── LLM (server-side fallback; users can also use BYOK in the UI) ─────────
# Provide at least one provider key if not using BYOK only.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3-flash-preview

ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20240620

# ── Algorand compiler (required) ───────────────────────────────────────────
COMPILER_SERVER_URL=https://your-puya-compiler.example

ALGORAND_TESTNET_URL=https://testnet-api.algonode.cloud
ALGORAND_MAINNET_URL=https://mainnet-api.algonode.cloud
ALGORAND_INDEXER_TESTNET=https://testnet-idx.algonode.cloud
ALGORAND_INDEXER_MAINNET=https://mainnet-idx.algonode.cloud
DEFAULT_NETWORK=testnet

# ── Post-deploy testnet simulation (optional) ──────────────────────────────
# Fund this account on testnet: https://bank.testnet.algorand.network/
SIMULATE_ENABLED=true
ALGORAND_SIMULATOR_MNEMONIC=

# ── Database (optional — build sessions default to JSON file) ─────────────
DATABASE_URL=postgresql://algocraft:algocraft@localhost:5432/algocraft

# ── Optional integrations ──────────────────────────────────────────────────
CONTEXT7_API_KEY=
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=

# ── App metadata ───────────────────────────────────────────────────────────
APP_NAME=AlgoVibe
DEBUG=false

# ── Frontend (frontend/.env.local for local dev) ───────────────────────────
# NEXT_PUBLIC_API_URL=http://localhost:8000
